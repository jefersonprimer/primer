---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";

const changelogEntries = await getCollection("changelog");
// Sort by date or version if needed
const entries = await Promise.all(
  changelogEntries.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);
---

<BaseLayout title="Changelog - Primer AI">
  <Navbar />
  <main class="px-6 py-24 max-w-3xl mx-auto">
    <h1 class="text-4xl font-bold mb-12">Changelog</h1>
    
    <div class="space-y-16">
      {entries.map(({ entry, Content }) => (
        <section>
          <div class="flex items-baseline gap-4 mb-4">
            <h2 class="text-2xl font-mono font-bold">{entry.data.version}</h2>
            <span class="text-neutral-500">{entry.data.date}</span>
          </div>
          <div class="prose prose-invert max-w-none">
            <Content />
          </div>
        </section>
      ))}
    </div>
  </main>
</BaseLayout>
