<section id="pricing" class="px-6 py-24 max-w-7xl mx-auto">
  <div class="text-center mb-16">
    <h2 class="text-3xl font-bold tracking-tight mb-4">Simple, transparent pricing</h2>
    <p class="text-neutral-400">Choose the plan that fits your needs.</p>
  </div>

  <div class="grid md:grid-cols-3 gap-8">
    <!-- Start Plan -->
    <div class="border border-white/10 rounded-2xl p-8 bg-neutral-900/50 flex flex-col">
      <div class="mb-6">
        <h3 class="text-xl font-medium mb-2">Start</h3>
        <p class="text-3xl font-bold">$0<span class="text-lg font-normal text-neutral-400">/mo</span></p>
        <p class="text-neutral-400 text-sm mt-2">Perfect for getting started</p>
      </div>
      <ul class="space-y-4 mb-8 flex-1 text-sm text-neutral-300">
        <li class="flex items-center gap-2">
          <svg class="w-5 h-5 text-neutral-100" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Basic AI responses
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-5 h-5 text-neutral-100" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          100 queries/month
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-5 h-5 text-neutral-100" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Community support
        </li>
      </ul>
      <a href="#" class="block text-center py-2 px-4 rounded-lg bg-white/10 hover:bg-white/20 transition-colors">Get Started</a>
    </div>

    <!-- Pro Plan -->
    <div class="border border-white/20 rounded-2xl p-8 bg-neutral-900 relative flex flex-col">
      <div class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1 bg-white text-black text-xs font-bold rounded-full">MOST POPULAR</div>
      <div class="mb-6">
        <h3 class="text-xl font-medium mb-2">Pro</h3>
        <p class="text-3xl font-bold">$29<span class="text-lg font-normal text-neutral-400">/mo</span></p>
        <p class="text-neutral-400 text-sm mt-2">For power users who need more</p>
      </div>
      <ul class="space-y-4 mb-8 flex-1 text-sm text-neutral-300">
        <li class="flex items-center gap-2">
          <svg class="w-5 h-5 text-neutral-100" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Everything in Start
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-5 h-5 text-neutral-100" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Unlimited queries
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-5 h-5 text-neutral-100" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Priority support
        </li>
         <li class="flex items-center gap-2">
          <svg class="w-5 h-5 text-neutral-100" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Advanced context window
        </li>
      </ul>
      <a href="#" class="block text-center py-2 px-4 rounded-lg bg-white text-black hover:bg-neutral-200 transition-colors">Upgrade to Pro</a>
    </div>

    <!-- Pro + Undetectability Plan -->
    <div class="border border-white/10 rounded-2xl p-8 bg-neutral-900/50 flex flex-col">
      <div class="mb-6">
        <h3 class="text-xl font-medium mb-2">Pro + Undetectability</h3>
        <p class="text-3xl font-bold">$49<span class="text-lg font-normal text-neutral-400">/mo</span></p>
        <p class="text-neutral-400 text-sm mt-2">Ultimate stealth & privacy</p>
      </div>
      <ul class="space-y-4 mb-8 flex-1 text-sm text-neutral-300">
        <li class="flex items-center gap-2">
          <svg class="w-5 h-5 text-neutral-100" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Everything in Pro
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-5 h-5 text-neutral-100" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Human-like typing patterns
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-5 h-5 text-neutral-100" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Anti-detection bypass
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-5 h-5 text-neutral-100" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Dedicated IP
        </li>
      </ul>
      <a href="#" class="block text-center py-2 px-4 rounded-lg bg-white/10 hover:bg-white/20 transition-colors">Go Stealth</a>
    </div>
  </div>
</section>
